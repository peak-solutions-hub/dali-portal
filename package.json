{
	"name": "dali-portal",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"dev:admin": "turbo run dev --filter=backend --filter=admin",
		"dev:portal": "turbo run dev --filter=backend --filter=portal",
		"dev:shared": "pnpm run dev --filter @repo/shared",
		"test": "pnpm run test:unit && pnpm run test:integration && pnpm run test:backend:e2e && pnpm run test:e2e",
		"test:unit": "turbo run test:unit",
		"test:integration": "turbo run test:integration",
		"test:backend:e2e": "pnpm --filter backend run test:e2e",
		"test:e2e": "pnpm --filter @repo/shared build && turbo run test:e2e --filter=portal-e2e --filter=admin-e2e --only --concurrency=1",
		"test:e2e:admin": "pnpm --filter @repo/shared build && turbo run test:e2e --filter=admin-e2e --only --concurrency=1",
		"test:e2e:portal": "pnpm --filter @repo/shared build && turbo run test:e2e --filter=portal-e2e --only --concurrency=1",
		"test:affected": "pnpm run test:affected:unit && pnpm run test:affected:integration && pnpm run test:backend:e2e && pnpm run test:affected:e2e",
		"test:affected:unit": "turbo run test:unit --filter=...[origin/main]",
		"test:affected:integration": "turbo run test:integration --filter=...[origin/main]",
		"test:affected:e2e": "pnpm --filter @repo/shared build && turbo run test:e2e --filter=admin-e2e[origin/main] --filter=portal-e2e[origin/main] --only --concurrency=1",
		"test:e2e:admin:affected": "pnpm --filter @repo/shared build && turbo run test:e2e --filter=admin-e2e[origin/main] --only --concurrency=1",
		"test:e2e:portal:affected": "pnpm --filter @repo/shared build && turbo run test:e2e --filter=portal-e2e[origin/main] --only --concurrency=1",
		"test:watch": "pnpm --filter backend run test:watch",
		"test:e2e:headed": "pnpm --filter @repo/shared build && turbo run test:e2e --filter=portal-e2e --filter=admin-e2e --only --concurrency=1 -- --headed",
		"test:e2e:ui": "pnpm run test:e2e:ui:both",
		"test:e2e:ui:ports:free": "kill-port 9323 9324",
		"test:e2e:ui:admin": "pnpm run test:e2e:ui:ports:free && dotenv -e apps/backend/.env.test -o -v PORT=8080 -- pnpm --filter admin-e2e exec playwright test --ui --ui-port=9323 --headed",
		"test:e2e:ui:portal": "pnpm run test:e2e:ui:ports:free && dotenv -e apps/backend/.env.test -o -v PORT=8081 -- pnpm --filter portal-e2e exec playwright test --ui --ui-port=9324 --headed",
		"test:e2e:ui:both": "pnpm run test:e2e:ui:ports:free && concurrently -k -n admin,portal -c cyan,green \"dotenv -e apps/backend/.env.test -o -v PORT=8080 -- pnpm --filter admin-e2e exec playwright test --ui --ui-port=9323 --headed\" \"dotenv -e apps/backend/.env.test -o -v PORT=8081 -- pnpm --filter portal-e2e exec playwright test --ui --ui-port=9324 --headed\"",
		"playwright:install": "playwright install --with-deps",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"check-types": "turbo run check-types",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.0",
		"@commitlint/cli": "^20.2.0",
		"@commitlint/config-conventional": "^20.2.0",
		"@playwright/test": "^1.58.2",
		"baseline-browser-mapping": "2.10.17",
		"concurrently": "^9.2.1",
		"dotenv-cli": "^7.4.4",
		"husky": "^9.1.7",
		"kill-port": "^2.0.1",
		"lint-staged": "^16.2.7",
		"turbo": "^2.6.3",
		"typescript": "5.9.3"
	},
	"lint-staged": {
		"*": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
	},
	"packageManager": "pnpm@9.0.0",
	"engines": {
		"node": ">=22"
	}
}
