{
	"$schema": "https://turborepo.com/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"env": ["BUILD_STANDALONE"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".next/**", "!.next/cache/**", "dist/**"]
		},
		"test": {
			"dependsOn": ["test:unit", "test:integration"]
		},
		"test:unit": {
			"outputs": ["coverage/**"]
		},
		"test:integration": {
			"outputs": ["coverage/**"]
		},
		"test:e2e": {
			"passThroughEnv": [
				"PLAYWRIGHT_*",
				"SUPABASE_*",
				"RESEND_API_KEY",
				"TURNSTILE_SECRET_KEY",
				"PORTAL_URL",
				"ADMIN_URL",
				"NEXT_PUBLIC_*",
				"TEST_*"
			],
			"cache": false
		},
		"check-types": {
			"dependsOn": ["^check-types", "^build"]
		},
		"dev": {
			"dependsOn": ["^build"],
			"cache": false,
			"persistent": true
		}
	}
}
