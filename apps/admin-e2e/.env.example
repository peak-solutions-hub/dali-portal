# Optional API override for direct API assertions in tests
E2E_API_BASE_URL=http://localhost:8080

# Required by auth session helpers
# Prefer matching backend test Supabase project used in apps/backend/.env.test
SUPABASE_URL=https://example.supabase.co
SUPABASE_ANON_KEY=test-supabase-anon-key

# Primary IT admin
E2E_IT_ADMIN_EMAIL=
E2E_IT_ADMIN_PASSWORD=

# Secondary IT admin (used for cross-admin demote/restore tests)
E2E_IT_ADMIN_2_EMAIL=
E2E_IT_ADMIN_2_PASSWORD=

# Non-admin baseline user
E2E_NON_ADMIN_EMAIL=
E2E_NON_ADMIN_PASSWORD=

# Deactivated user account
E2E_DEACTIVATED_EMAIL=
E2E_DEACTIVATED_PASSWORD=

# Role-matrix login and sidebar tests
E2E_VICE_MAYOR_EMAIL=
E2E_VICE_MAYOR_PASSWORD=
E2E_HEAD_ADMIN_EMAIL=
E2E_HEAD_ADMIN_PASSWORD=
E2E_ADMIN_STAFF_EMAIL=
E2E_ADMIN_STAFF_PASSWORD=
E2E_LEGISLATIVE_STAFF_EMAIL=
E2E_LEGISLATIVE_STAFF_PASSWORD=
E2E_OVM_STAFF_EMAIL=
E2E_OVM_STAFF_PASSWORD=
