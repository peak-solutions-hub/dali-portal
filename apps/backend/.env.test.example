# Dedicated Supabase test database URL.
NODE_ENV="test"

PORT=8080

DATABASE_URL=DB_URL_HERE

TEST_DB_ALLOWED_HOSTS="*.pooler.supabase.com"

TEST_DB_ALLOWED_PROJECT_REFS="projectrefhere"

SUPABASE_URL="https://example.supabase.co"
SUPABASE_ANON_KEY="test_anon_key"
SUPABASE_SERVICE_ROLE_KEY="test_service_role_key"
SUPABASE_JWT_SECRET="test_jwt_secret"

# Optional in test mode: config.ts falls back to test keys when NODE_ENV="test".
# Keep these for explicitness in CI/local if preferred.
TURNSTILE_SECRET_KEY="test-turnstile-secret-key"
RESEND_API_KEY="test-resend-api-key"


