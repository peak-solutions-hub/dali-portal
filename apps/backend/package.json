{
	"name": "backend",
	"version": "0.0.1",
	"description": "",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"files": [
		"dist"
	],
	"scripts": {
		"postinstall": "prisma generate",
		"build": "nest build",
		"dev": "nest start --watch",
		"format": "biome format --write",
		"lint": "biome check",
		"start": "nest start",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/src/app/main",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev",
		"db:migrate:deploy": "prisma migrate deploy",
		"db:test:generate": "prisma generate --config prisma.test.config.ts",
		"db:test:migrate": "prisma migrate deploy --config prisma.test.config.ts",
		"db:test:prepare": "pnpm run db:test:generate",
		"db:test:pull": "prisma db pull --config prisma.test.config.ts",
		"db:test:push": "prisma db push --config prisma.test.config.ts",
		"db:test:reset": "prisma db execute --config prisma.test.config.ts --file ./test/sql/reset-public.sql",
		"db:pull": "prisma db pull",
		"db:push": "prisma db push",
		"db:studio": "prisma studio",
		"test": "pnpm run test:unit && pnpm run test:integration",
		"test:unit": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config ./test/jest-unit.config.ts",
		"test:integration": "pnpm run db:test:prepare && node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config ./test/jest-integration.config.ts",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"
	},
	"dependencies": {
		"@nestjs/axios": "^4.0.1",
		"@nestjs/common": "^11.0.1",
		"@nestjs/config": "^4.0.2",
		"@nestjs/core": "^11.0.1",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-express": "^11.0.1",
		"@nestjs/throttler": "^6.5.0",
		"@orpc/nest": "1.13.4",
		"@orpc/zod": "1.13.4",
		"@prisma/adapter-pg": "^7.2.0",
		"@prisma/client": "^7.2.0",
		"@repo/shared": "workspace:*",
		"@scalar/nestjs-api-reference": "^1.0.13",
		"nanoid": "^5.1.6",
		"nestjs-zod": "^5.0.1",
		"passport": "^0.7.0",
		"passport-jwt": "^4.0.1",
		"reflect-metadata": "^0.2.2",
		"resend": "^6.8.0",
		"rxjs": "^7.8.1"
	},
	"devDependencies": {
		"@nestjs/cli": "^11.0.0",
		"@nestjs/schematics": "^11.0.0",
		"@nestjs/testing": "^11.0.1",
		"@types/express": "^5.0.0",
		"@types/jest": "^29.5.14",
		"@types/node": "^22.10.7",
		"@types/passport-jwt": "^4.0.1",
		"@types/supertest": "^6.0.2",
		"jest": "^29.7.0",
		"prisma": "^7.2.0",
		"source-map-support": "^0.5.21",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.5",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"type-fest": "^5.3.1",
		"typescript": "5.9.3"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}
